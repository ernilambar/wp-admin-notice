<phpunit colors="true" bootstrap="tests/bootstrap.php">
    <testsuites>
        <testsuite name="My Project Tests">
            <directory suffix=".php">./tests/cases/</directory>
        </testsuite>
    </testsuites>

		<php>
        <env name="WP_PHPUNIT__TESTS_CONFIG" value="tests/wp-tests-config.php" />
    </php>
</phpunit>
